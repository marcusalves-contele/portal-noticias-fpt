{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "watchPatterns": ["prism-os/**"]
  },
  "deploy": {
    "startCommand": "cd nutella-creator && python3 boot.py && python3 dashboard.py",
    "healthcheckPath": "/",
    "restartPolicyType": "ON_FAILURE"
  }
}
